# ============================================================
# CoC 봇 설정 파일
# ============================================================
# 사용법: cp .env.example .env  후 아래 값을 채우세요.
# 보통은 install.sh 가 자동 생성하므로 직접 만들 일은 없습니다.

# ------------------------------------------------------------
# 마스토돈 (필수)
# ------------------------------------------------------------

# 봇이 접속할 마스토돈 서버 주소 (https:// 포함)
MASTODON_API_BASE_URL=https://example.xyz

# 봇 계정의 액세스 토큰
MASTODON_ACCESS_TOKEN=

# ------------------------------------------------------------
# Google Sheets (3개 모두 필수)
# ------------------------------------------------------------
# 서비스 계정 이메일이 세 시트 모두에 '편집자' 로 공유되어 있어야 합니다.

# CoC 캐릭터 시트 — 능력치/기능/무기/도움말 등이 들어 있는 메인 시트
SHEET_ID=

# 랜덤표 시트 — 워크시트 이름 = 명령어, 컬럼 A 의 값 중 무작위로 1개 반환
RANDOM_TABLE_SHEET_ID=

# 커스텀 명령어 시트 — '커스텀' 워크시트의 명령어/문구 매핑
CUSTOM_COMMAND_SHEET_ID=

# ------------------------------------------------------------
# 알림 / 가동 기간 (선택)
# ------------------------------------------------------------

# 오류 알림 받을 KPC/GM 계정 (@ 없이, 콤마로 여러 명 가능)
SYSTEM_ADMIN_ID=

# 가동 시작일 (KST 기준 YYYY-MM-DD, 비우면 즉시 시작)
OPERATION_START_DATE=

# 가동 종료일 (KST 기준 YYYY-MM-DD, 비우면 무기한)
# 종료일 00:00 부터 사용자당 1회 만료 안내 후 침묵.
OPERATION_END_DATE=
